# ─── Core ────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+asyncpg://career:career_dev@postgres:5432/career_os
REDIS_URL=redis://redis:6379/0

# ─── LLM / Embeddings ───────────────────────────────────
# Default provider is "ollama" -- free, runs locally, no API key needed.
# Install Ollama (https://ollama.com) then run:
#   ollama pull llama3.1
#   ollama pull nomic-embed-text
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# To use paid OpenAI models instead, set LLM_PROVIDER=openai and fill these in
# (also run: pip install -e ".[openai]"). EMBEDDING_DIM must become 1536.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ─── Email (OAuth 2.0) ──────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/email/oauth/callback
# Store refresh tokens in OS keychain or Vault -- never in DB

# ─── Browser automation ─────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_USER_DATA_DIR=/app/data/browser_profile

# ─── Legal policy ───────────────────────────────────────
RESPECT_ROBOTS_TXT=true
DEFAULT_SOURCE_POLICY=API_ALLOWED
MAX_REQUESTS_PER_MINUTE=30

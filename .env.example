# ─── Core ────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+asyncpg://career:career_dev@postgres:5432/career_os
REDIS_URL=redis://redis:6379/0

# ─── LLM / Embeddings ───────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ─── Email (OAuth 2.0) ──────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/email/oauth/callback
# Store refresh tokens in OS keychain or Vault -- never in DB

# ─── Browser automation ─────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_USER_DATA_DIR=/app/data/browser_profile

# ─── Legal policy ───────────────────────────────────────
RESPECT_ROBOTS_TXT=true
DEFAULT_SOURCE_POLICY=API_ALLOWED
MAX_REQUESTS_PER_MINUTE=30
